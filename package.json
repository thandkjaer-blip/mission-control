{
  "name": "mission-control",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "infra:up": "bash infra/scripts/infra-up.sh",
    "infra:down": "bash infra/scripts/infra-down.sh",
    "infra:reset": "bash infra/scripts/infra-reset.sh",
    "local:doctor": "bash infra/scripts/local-doctor.sh",
    "local:restart-api": "bash infra/scripts/local-restart-api.sh",
    "db:migrate": "corepack pnpm --filter @mission-control/api exec prisma migrate dev",
    "db:generate": "corepack pnpm --filter @mission-control/api exec prisma generate",
    "db:seed": "corepack pnpm --filter @mission-control/api db:seed",
    "runtime:refresh": "bash infra/scripts/runtime-refresh.sh"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
